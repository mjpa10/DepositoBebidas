    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UserSecretsId>c802e305-6999-455d-b1b1-02acc12d756a</UserSecretsId>
  </PropertyGroup>

	<ItemGroup>
